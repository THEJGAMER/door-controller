# --- Application Settings ---
PORT=4000
BASE_URL=https://acs.yourdomain.com

# --- OIDC / Keycloak Settings ---
# The full URL to your Keycloak realm (e.g. https://keycloak.domain.com/realms/master)
OIDC_ISSUER_URL=
# The Client ID created in your OIDC provider
OIDC_CLIENT_ID=
# The Client Secret from your OIDC provider
OIDC_CLIENT_SECRET=
# A long random string used to sign session cookies
OIDC_SECRET=

# --- UHPPOTE Network Settings ---
# Local IP address to bind the UDP socket (0.0.0.0 for all interfaces)
UHPPOTE_BIND=0.0.0.0
# The broadcast address for your subnet (e.g. 192.168.1.255:60000)
UHPPOTE_BROADCAST=
# Local IP and Port to listen for controller events (default 0.0.0.0:60001)
UHPPOTE_LISTEN=0.0.0.0:60001
# Command timeout in milliseconds
UHPPOTE_TIMEOUT=5000
# Set to 'true' to log raw UDP packets to the console
UHPPOTE_DEBUG=false
